	<queryString>
		<![CDATA[select so_nbr, sod_item, sod_desc, sod_ord_qty,
so_cust, so_due_date, so_shipvia,  
so_po, sod_ord_qty, sod_uom 
cm_code, cm_name, cm_line1, 
cm_line2, 
cms_name, cms_line1, cms_line2, 
site_desc, site_line1 
from sod_det 
inner join so_mstr on so_nbr = sod_nbr 
inner join cm_mstr on cm_code = so_cust 
left outer join cms_det on cms_code = so_cust and cms_shipto = so_ship 
inner join site_mstr on site_site = so_site 
where sod_nbr =  $P{mynbr} and sod_line = $P{myline}]]>
	</queryString>
