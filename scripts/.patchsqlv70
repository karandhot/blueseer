/* sql updates for v7.0  */

select '*** ALTER SCHEMA SECTION ***';
select '';


set @field = 'as2_sysenccert'; set @table = 'as2_mstr';
set @sql = concat('Alter table ', @table, ' add column ' ,@field, ' varchar(120) not null default \'\' ' );
SELECT count(*) into @Cnt FROM information_schema.columns WHERE table_name = @table AND column_name = @field and table_schema = DATABASE();
set @query = IF(@Cnt <= 0, @sql, 'set @noreturnjunk = \'\'');
prepare stmt from @query; EXECUTE stmt;
select @field, case when @Cnt > 0 then 'Exists' else 'Inserting' end as status;

set @field = 'as2_syssigncert'; set @table = 'as2_mstr';
set @sql = concat('Alter table ', @table, ' add column ' ,@field, ' varchar(120) not null default \'\' ' );
SELECT count(*) into @Cnt FROM information_schema.columns WHERE table_name = @table AND column_name = @field and table_schema = DATABASE();
set @query = IF(@Cnt <= 0, @sql, 'set @noreturnjunk = \'\'');
prepare stmt from @query; EXECUTE stmt;
select @field, case when @Cnt > 0 then 'Exists' else 'Inserting' end as status;

set @field = 'as2_syscert_bool'; set @table = 'as2_mstr';
set @sql = concat('Alter table ', @table, ' add column ' ,@field, ' tinyint(1) not null default \'0\' ' );
SELECT count(*) into @Cnt FROM information_schema.columns WHERE table_name = @table AND column_name = @field and table_schema = DATABASE();
set @query = IF(@Cnt <= 0, @sql, 'set @noreturnjunk = \'\'');
prepare stmt from @query; EXECUTE stmt;
select @field, case when @Cnt > 0 then 'Exists' else 'Inserting' end as status;

